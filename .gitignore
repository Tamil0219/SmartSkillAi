# ============================================================
# SmartSkill-AI — Root .gitignore
# Covers: React/Vite frontend + Node.js/Express backend
# ============================================================

# ── Dependencies ────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Lock files (regenerated on install — not needed in repo) ─
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Environment variables ────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── Build outputs ────────────────────────────────────────────
dist/
build/
.vite/
out/

# ── Test coverage ────────────────────────────────────────────
coverage/
.nyc_output/

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / system files ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE and editor directories ───────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── AI / Kiro / Gemini tool directories ─────────────────────
.kiro/
.gemini/

# ── Uploaded user files (runtime-generated) ─────────────────
backend/uploads/

# ── Temporary / local-only scripts ──────────────────────────
powershell.bat
push_project.bat
fix-lint.cjs
Eula.txt

# ── Sysinternals / tool output files ────────────────────────
handle_*.txt
handle_output.txt
query

# ── Binaries and archives ────────────────────────────────────
*.exe
*.zip
*.tar.gz
*.rar

# ── Debug / one-off backend scripts ─────────────────────────
backend/debug_*.js
backend/test*.js
backend/find*.js
backend/clean*.js
backend/verify*.js
backend/reset*.js
backend/seed*.js
backend/setup-login.js
