# Backend Environment Variables
# Copy this file to .env and fill in your actual values
# Set ALL of these in your Render dashboard under Environment

# Server
PORT=5000
NODE_ENV=production

# Security — use a long random string (64+ chars)
JWT_SECRET=your_secure_jwt_secret_here

# Database — MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# Frontend URL — must match your deployed Vercel URL exactly (for CORS)
CLIENT_URL=https://smart-skill-ai.vercel.app

# AI Keys (optional — chatbot falls back to canned responses without these)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key
