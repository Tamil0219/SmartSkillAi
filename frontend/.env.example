# Frontend Environment Variables
# Local Development (default)
VITE_API_URL=https://smartskill-ai-3.onrender.com/api

# For Deployment on Vercel:
# Set this environment variable in Vercel to your Render backend URL.
# Example:
# VITE_API_URL=https://<your-backend-service>.onrender.com/api

# Leave empty only if your frontend and backend are deployed to the same domain
# and the API is available under /api.
